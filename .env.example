# Database
POSTGRES_DB=fundpilot
POSTGRES_USER=fundpilot
POSTGRES_PASSWORD=fundpilot

# Backend
DB_URL=jdbc:postgresql://db:5432/fundpilot
DB_USER=fundpilot
DB_PASSWORD=fundpilot
APP_SEED_DEMO=true

# Scoring overrides (optional)
SCORING_STRONG_BUY_THRESHOLD=80
SCORING_BUY_THRESHOLD=65
SCORING_HOLD_THRESHOLD=45
SCORING_WEIGHT_RETURN1Y=0.35
SCORING_WEIGHT_MA=0.25
SCORING_WEIGHT_PERCENTILE=0.15
SCORING_WEIGHT_DRAWDOWN=0.15
SCORING_WEIGHT_BENCHMARK=0.10
